<div class="page-header">
  <h1>主题配置</h1>
  <button class="btn btn-primary" onclick="saveConfig()">保存配置</button>
</div>

<div class="tabs">
  <div class="tab active" onclick="switchTab('theme')">主题设置</div>
  <div class="tab" onclick="switchTab('styles')">自定义样式</div>
</div>

<!-- Theme Settings Tab -->
<div id="tab-theme">
  <div class="card">
    <h3>背景图片</h3>
    <div class="toggle-group mb-md">
      <div class="toggle" id="toggle-bg" onclick="this.classList.toggle('on')"></div>
      <label>启用背景图片</label>
    </div>
    <div class="form-row">
      <div class="form-group"><label for="bgUrl">日间背景</label><input type="text" id="bgUrl" placeholder="/background/bg_day.jpg"></div>
      <div class="form-group"><label for="bgDark">夜间背景</label><input type="text" id="bgDark" placeholder="/background/bg_dark.jpg"></div>
      <div class="form-group"><label for="bgOpacity">透明度 (0-1)</label><input type="number" id="bgOpacity" min="0" max="1" step="0.1"></div>
    </div>
  </div>

  <div class="card">
    <h3>横幅</h3>
    <div class="toggle-group mb-md">
      <div class="toggle" id="toggle-banner" onclick="this.classList.toggle('on')"></div>
      <label>启用横幅</label>
    </div>
    <div class="form-group"><label for="bannerTitle">横幅文字 (逗号分隔每个字)</label><input type="text" id="bannerTitle" placeholder="A,k,u,k,i,n,的,咖,啡,馆"></div>
  </div>

  <div class="card">
    <h3>烟花特效</h3>
    <div class="toggle-group mb-md">
      <div class="toggle" id="toggle-fw" onclick="this.classList.toggle('on')"></div>
      <label>启用烟花</label>
    </div>
    <div class="form-group"><label for="fwColors">颜色 (JSON 数组)</label><input type="text" id="fwColors" placeholder='["#d096dfff","#a7d1f3ff","rgba(240,166,255,1)"]'></div>
  </div>

  <div class="card">
    <h3>导航页面</h3>
    <div id="nav-pages-list"></div>
    <button class="btn btn-outline mt-sm" onclick="addNavPage()">+ 添加导航页</button>
  </div>

  <div class="card">
    <h3>页脚</h3>
    <div class="form-row">
      <div class="form-group"><label for="footerSince">起始年份</label><input type="number" id="footerSince"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label for="icpEnable">ICP 备案开关</label>
        <div class="toggle on" id="toggle-icp" onclick="this.classList.toggle('on')"></div>
      </div>
      <div class="form-group"><label for="icp">ICP 备案号</label><input type="text" id="icp"></div>
    </div>
  </div>

  <div class="card">
    <h3>Waline 评论</h3>
    <div class="form-row">
      <div class="form-group"><label for="walineServer">Server URL</label><input type="text" id="walineServer"></div>
    </div>
    <div class="toggle-group mb-md">
      <div class="toggle" id="toggle-comment" onclick="this.classList.toggle('on')"></div>
      <label>启用评论</label>
      &nbsp;&nbsp;
      <div class="toggle" id="toggle-pageview" onclick="this.classList.toggle('on')"></div>
      <label>启用阅读量</label>
    </div>
  </div>
</div>

<!-- Custom Styles Tab -->
<div id="tab-styles" style="display:none">
  <div class="card">
    <h3>CSS/SCSS 自定义样式</h3>
    <div class="form-group">
      <label for="stylesContent">styles/index.scss</label>
      <textarea id="stylesContent" class="code large" style="min-height:500px" placeholder="// 加载中..."></textarea>
    </div>
    <div class="flex gap-sm">
      <button class="btn btn-primary" onclick="saveStyles()">保存样式</button>
    </div>
  </div>
</div>

<script>
var navPages = []

async function loadConfig() {
  try {
    var data = await api('GET', '/api/config/theme')

    // Background
    if (data.themeConfig && data.themeConfig.bg_image) {
      document.querySelector('#toggle-bg').classList.toggle('on', data.themeConfig.bg_image.enable)
      document.querySelector('#bgUrl').value = data.themeConfig.bg_image.url || ''
      document.querySelector('#bgDark').value = data.themeConfig.bg_image.dark || ''
      document.querySelector('#bgOpacity').value = data.themeConfig.bg_image.opacity || 0.6
    }

    // Banner
    if (data.themeConfig && data.themeConfig.banner) {
      document.querySelector('#toggle-banner').classList.toggle('on', data.themeConfig.banner.enable)
      document.querySelector('#bannerTitle').value = (data.themeConfig.banner.title || []).join(',')
    }

    // Fireworks
    if (data.themeConfig && data.themeConfig.fireworks) {
      document.querySelector('#toggle-fw').classList.toggle('on', data.themeConfig.fireworks.enable)
      document.querySelector('#fwColors').value = JSON.stringify(data.themeConfig.fireworks.colors || [])
    }

    // Nav pages
    navPages = (data.themeConfig && data.themeConfig.pages) ? data.themeConfig.pages : []
    renderNavPages()

    // Footer
    if (data.themeConfig && data.themeConfig.footer) {
      document.querySelector('#footerSince').value = data.themeConfig.footer.since || ''
      if (data.themeConfig.footer.beian) {
        document.querySelector('#toggle-icp').classList.toggle('on', data.themeConfig.footer.beian.enable)
        document.querySelector('#icp').value = data.themeConfig.footer.beian.icp || ''
      }
    }

    // Waline
    if (data.addons) {
      var waline = data.addons.find(function(a) { return a.name === 'valaxy-addon-waline' })
      if (waline) {
        document.querySelector('#walineServer').value = waline.options.serverURL || ''
        document.querySelector('#toggle-comment').classList.toggle('on', waline.options.comment !== false)
        document.querySelector('#toggle-pageview').classList.toggle('on', waline.options.pageview !== false)
      }
    }

  } catch(e) { toast('加载配置失败: ' + e.message, 'error') }
}

function renderNavPages() {
  var html = ''
  navPages.forEach(function(p, i) {
    html += '<div class="form-row mb-sm"><div class="form-group"><input placeholder="名称" value="' + esc(p.name) + '" onchange="navPages[' + i + '].name=this.value"></div>' +
      '<div class="form-group"><input placeholder="URL" value="' + esc(p.url) + '" onchange="navPages[' + i + '].url=this.value"></div>' +
      '<div class="form-group"><input placeholder="图标" value="' + esc(p.icon||'') + '" onchange="navPages[' + i + '].icon=this.value"></div>' +
      '<div class="form-group"><input placeholder="颜色" value="' + esc(p.color||'') + '" onchange="navPages[' + i + '].color=this.value"></div>' +
      '<button class="btn btn-danger" style="padding:4px 8px;font-size:12px" onclick="navPages.splice(' + i + ',1);renderNavPages()">删除</button></div>'
  })
  document.querySelector('#nav-pages-list').innerHTML = html || '<p class="empty">暂无导航页面</p>'
}

function addNavPage() { navPages.push({ name: '', url: '', icon: '', color: '' }); renderNavPages() }

async function saveConfig() {
  var data = {
    themeConfig: {
      bg_image: {
        enable: document.querySelector('#toggle-bg').classList.contains('on'),
        url: document.querySelector('#bgUrl').value,
        dark: document.querySelector('#bgDark').value,
        opacity: parseFloat(document.querySelector('#bgOpacity').value) || 0.6
      },
      banner: {
        enable: document.querySelector('#toggle-banner').classList.contains('on'),
        title: document.querySelector('#bannerTitle').value.split(',').filter(function(s) { return s.trim() })
      },
      fireworks: {
        enable: document.querySelector('#toggle-fw').classList.contains('on'),
        colors: (function() {
          try { return JSON.parse(document.querySelector('#fwColors').value) } catch(e) { return [] }
        })()
      },
      pages: navPages,
      footer: {
        since: parseInt(document.querySelector('#footerSince').value) || undefined,
        beian: {
          enable: document.querySelector('#toggle-icp').classList.contains('on'),
          icp: document.querySelector('#icp').value
        }
      }
    },
    waline: {
      serverURL: document.querySelector('#walineServer').value,
      comment: document.querySelector('#toggle-comment').classList.contains('on'),
      pageview: document.querySelector('#toggle-pageview').classList.contains('on')
    }
  }
  try {
    await api('PUT', '/api/config/theme', data)
    toast('主题配置已保存', 'success')
  } catch(e) { toast('保存失败: ' + e.message, 'error') }
}

async function loadStyles() {
  try {
    var data = await api('GET', '/api/config/styles')
    document.querySelector('#stylesContent').value = data.content || ''
  } catch(e) { toast('加载样式失败: ' + e.message, 'error') }
}

async function saveStyles() {
  try {
    await api('PUT', '/api/config/styles', { content: document.querySelector('#stylesContent').value })
    toast('样式已保存', 'success')
  } catch(e) { toast('保存失败: ' + e.message, 'error') }
}

function switchTab(name) {
  document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active') })
  event.target.classList.add('active')
  document.querySelector('#tab-theme').style.display = name === 'theme' ? '' : 'none'
  document.querySelector('#tab-styles').style.display = name === 'styles' ? '' : 'none'
  if (name === 'styles') loadStyles()
}

function esc(s) {
  if (!s) return ''
  var d = document.createElement('div')
  d.textContent = s
  return d.innerHTML
}

loadConfig()
</script>
