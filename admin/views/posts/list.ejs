<div class="page-header">
  <h1>文章管理</h1>
  <a href="/admin/posts/new" class="btn btn-primary">+ 新建文章</a>
</div>

<div class="card">
  <div class="flex-between mb-md">
    <input type="text" id="search" class="form-group" placeholder="搜索文章标题..." style="margin-bottom:0;width:300px" oninput="renderTable()">
  </div>
  <div class="table-wrap">
    <table id="post-table">
      <thead><tr><th>标题</th><th>分类</th><th>标签</th><th>日期</th><th>状态</th><th>操作</th></tr></thead>
      <tbody id="post-tbody"><tr><td colspan="6" class="empty">加载中...</td></tr></tbody>
    </table>
  </div>
</div>

<script>
var allPosts = []

async function loadPosts() {
  try {
    allPosts = await api('GET', '/api/posts')
    renderTable()
  } catch(e) { document.querySelector('#post-tbody').innerHTML = '<tr><td colspan="6" class="empty">加载失败: ' + e.message + '</td></tr>' }
}

function renderTable() {
  var search = (document.querySelector('#search').value || '').toLowerCase()
  var filtered = allPosts.filter(function(p) { return (p.title || '').toLowerCase().indexOf(search) !== -1 })

  var html = ''
  filtered.forEach(function(p) {
    var tags = (p.tags || []).map(function(t) { return '<span class="tag">' + esc(t) + '</span>' }).join(' ')
    html += '<tr>' +
      '<td><strong>' + esc(p.title || '无标题') + '</strong></td>' +
      '<td>' + esc(p.categories || '-') + '</td>' +
      '<td>' + (tags || '-') + '</td>' +
      '<td>' + esc(p.date || '-') + '</td>' +
      '<td>' + (p.draft ? '草稿' : '已发布') + '</td>' +
      '<td>' +
        '<a href="/admin/posts/' + p.slug + '/edit" class="btn btn-outline" style="padding:4px 10px;font-size:12px">编辑</a> ' +
        '<button class="btn btn-danger" style="padding:4px 10px;font-size:12px" onclick="deletePost(\'' + esc(p.slug) + '\')">删除</button>' +
      '</td>' +
      '</tr>'
  })
  if (!html) html = '<tr><td colspan="6" class="empty">没有找到文章</td></tr>'
  document.querySelector('#post-tbody').innerHTML = html
}

async function deletePost(slug) {
  if (!confirm('确定要删除这篇文章吗？此操作不可恢复！')) return
  try {
    await api('DELETE', '/api/posts/' + slug)
    toast('删除成功', 'success')
    loadPosts()
  } catch(e) { toast('删除失败: ' + e.message, 'error') }
}

function esc(s) {
  if (!s) return ''
  var d = document.createElement('div')
  d.textContent = s
  return d.innerHTML
}

loadPosts()
</script>
