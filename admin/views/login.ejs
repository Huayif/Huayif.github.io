<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登录 - 博客管理后台</title>
  <link rel="stylesheet" href="/admin/static/css/admin.css">
</head>
<body style="display:block">  <!-- 覆盖全局 flex，登录页不需要侧边栏布局 -->
  <div class="login-page">
    <div class="login-card">
      <h1>🌸 博客管理后台</h1>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/admin/login">
        <div class="form-group">
          <label for="password">管理员密码</label>
          <input type="password" id="password" name="password" placeholder="请输入密码" required autofocus>
        </div>
        <button type="submit" class="btn btn-primary">登 录</button>
      </form>
    </div>
  </div>
</body>
</html>
