<div class="page-header">
  <h1>Git 管理</h1>
  <div class="flex gap-sm">
    <button class="btn btn-outline" onclick="refreshStatus()">刷新状态</button>
    <button class="btn btn-success" id="btn-commit" onclick="doCommit()">提交变更</button>
    <button class="btn btn-primary" id="btn-push" onclick="doPush()">推送</button>
  </div>
</div>

<div class="card">
  <div class="flex-between mb-md">
    <h3>工作区状态</h3>
    <span id="branch-name" style="font-size:13px;color:var(--text-dim)"></span>
  </div>
  <div id="git-status-content"><div class="empty"><span class="empty-icon"></span><p>加载中...</p></div></div>
</div>

<div class="card" id="commit-card" style="display:none">
  <h3>提交变更</h3>
  <div class="form-group">
    <label for="commit-message">提交信息</label>
    <input type="text" id="commit-message" placeholder="描述本次变更内容">
  </div>
  <div class="flex gap-sm">
    <button class="btn btn-success" onclick="confirmCommit()">确认提交</button>
    <button class="btn btn-outline" onclick="document.querySelector('#commit-card').style.display='none'">取消</button>
  </div>
</div>

<div class="card">
  <div class="flex-between mb-md">
    <h3>最近提交</h3>
  </div>
  <div id="git-log"><div class="empty"><p>加载中...</p></div></div>
</div>

<div class="card">
  <p style="font-size:13px;color:var(--text-dim)">
    你的工作流程：编辑文章 → 提交 → 推送 → GitHub Actions 自动构建部署<br>
    不需要在本地手动构建。
  </p>
</div>

<script>
async function refreshStatus() {
  try {
    var data = await api('GET', '/api/git/status')
    document.querySelector('#branch-name').textContent = '分支: ' + data.branch

    var html = ''
    if (data.files.length === 0) {
      html = '<div class="empty"><span class="empty-icon"></span><p>工作区干净，没有待提交的变更</p></div>'
    } else {
      html = '<p class="mb-sm" style="font-size:13px;color:var(--text-dim)">变更文件 (' + data.files.length + '):</p>'
      data.files.forEach(function(f) {
        html += '<div class="git-file"><span class="indicator modified"></span>' + esc(f) + '</div>'
      })
    }
    document.querySelector('#git-status-content').innerHTML = html
  } catch(e) { toast('获取状态失败: ' + e.message, 'error') }
}

async function loadLog() {
  try {
    var data = await api('GET', '/api/git/log')
    var html = ''
    data.forEach(function(c) {
      html += '<div style="padding:8px 0;border-bottom:1px solid var(--border)">' +
        '<div class="flex-between"><strong style="font-family:monospace;font-size:13px">' + esc(c.hash) + '</strong>' +
        '<span style="font-size:12px;color:var(--text-dim)">' + esc(c.date) + '</span></div>' +
        '<div style="font-size:14px;margin-top:4px">' + esc(c.message) + '</div>' +
        '<div style="font-size:12px;color:var(--text-dim);margin-top:2px">' + esc(c.author) + '</div>' +
        '</div>'
    })
    document.querySelector('#git-log').innerHTML = html || '<div class="empty"><p>暂无提交记录</p></div>'
  } catch(e) { document.querySelector('#git-log').innerHTML = '<div class="empty"><p>加载失败</p></div>' }
}

function doCommit() {
  document.querySelector('#commit-card').style.display = ''
}

async function confirmCommit() {
  var msg = document.querySelector('#commit-message').value.trim()
  if (!msg) { toast('请输入提交信息', 'error'); return }
  try {
    await api('POST', '/api/git/commit', { message: msg })
    toast('提交成功', 'success')
    document.querySelector('#commit-card').style.display = 'none'
    document.querySelector('#commit-message').value = ''
    refreshStatus()
    loadLog()
  } catch(e) { toast('提交失败: ' + e.message, 'error') }
}

async function doPush() {
  if (!confirm('确定推送到远程仓库吗？')) return
  try {
    await api('POST', '/api/git/push')
    toast('推送成功', 'success')
  } catch(e) { toast('推送失败: ' + e.message, 'error') }
}

function esc(s) {
  if (!s) return ''
  var d = document.createElement('div')
  d.textContent = s
  return d.innerHTML
}

refreshStatus()
loadLog()
</script>
